{
  "private": true,
  "name": "playcalledit",
  "version": "0.0.0",
  "license": "BSD-3-Clause",
  "type": "module",
  "scripts": {
    "build": "vite build",
    "deploy": "npm run type-check && npm run lint && devvit upload",
    "dev": "devvit playtest",
    "launch": "npm run deploy && devvit publish",
    "lint": "eslint \"src/**/*.{ts,tsx}\"",
    "login": "devvit login",
    "prettier": "prettier --write .",
    "type-check": "tsc --build",
    "test": "vitest run",
    "preview:mock": "node tools/mock-server.mjs"
  },
  "engines": {
    "node": ">=22.2.0"
  },
  "dependencies": {
    "@devvit/start": "0.13.7",
    "@devvit/web": "0.13.7",
    "@hono/node-server": "2.0.6",
    "hono": "4.12.27",
    "phaser": "^4.2.0"
  },
  "devDependencies": {
    "@eslint/js": "10.0.1",
    "@fontsource/bricolage-grotesque": "^5.2.10",
    "@fontsource/ibm-plex-mono": "^5.2.7",
    "@fontsource/instrument-serif": "^5.2.8",
    "@fontsource/space-grotesk": "^5.2.10",
    "@types/node": "^22.19.19",
    "devvit": "^0.13.7",
    "eslint": "10.4.1",
    "globals": "17.7.0",
    "prettier": "3.8.4",
    "typescript": "6.0.3",
    "typescript-eslint": "8.60.1",
    "vite": "8.1.0",
    "vitest": "^4.1.9"
  },
  "allowScripts": {
    "esbuild@0.25.9": true,
    "protobufjs@7.5.8": true
  }
}
